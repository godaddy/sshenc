    classDef thirdparty fill:#F1F5F9,stroke:#64748B,stroke-width:1.5px,color:#334155,font-weight:bold
    classDef policyprocess fill:#FEF3C7,stroke:#D97706,stroke-width:1.5px,color:#78350F,font-weight:bold
    classDef cryptoprocess fill:#E9D5FF,stroke:#7C3AED,stroke-width:1.5px,color:#5B21B6,font-weight:bold
    classDef hw fill:#DDD6FE,stroke:#7C3AED,stroke-width:2px,color:#5B21B6,font-weight:bold
    classDef weakbackend fill:#FEE2E2,stroke:#DC2626,stroke-width:1.5px,stroke-dasharray:5 3,color:#7F1D1D
    classDef ipcnode fill:#ECFEFF,stroke:#0891B2,stroke-width:1.5px,color:#164E63
